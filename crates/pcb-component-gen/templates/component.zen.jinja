"""
{{ component_name }}

Auto-generated using `{{ generated_by }}`.
"""

{% if include_skip_bom %}
skip_bom = config(bool, default = {{ "True" if skip_bom_default else "False" }})
{% endif %}
{% if include_skip_pos %}
skip_pos = config(bool, default = {{ "True" if skip_pos_default else "False" }})
{% endif %}

Pins = struct(
{%- for pin in pin_groups %}
    {{ pin.sanitized_name }} = io("{{ pin.sanitized_name }}", Net){{ "," if not loop.last }}
{%- endfor %}
)

Component(
    name = "{{ component_name }}",
{%- if include_skip_bom %}
    skip_bom = skip_bom,
{%- endif %}
{%- if include_skip_pos %}
    skip_pos = skip_pos,
{%- endif %}
    symbol = Symbol(library = "{{ sym_path }}"),
    pins = {
{%- for pin in pin_mappings %}
        "{{ pin.original_name }}": Pins.{{ pin.sanitized_name }}{{ "," if not loop.last }}
{%- endfor %}
    },
)
